<html>
<head>
    <title>ExpressFiles</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 text-white">
   <h1 class="text-center text-5xl mt-3 font-bold">Express Files</h1>
   <form action="/create" method="post" class="flex items-center justify-center">
        <div class="form flex flex-col gap-4 mt-10 p-10 ">
            <input type="text" name="title" placeholder="Task Name" class="w-72 bg-zinc-800 outline-none px-4 py-2">
            <textarea type="text" name="details" placeholder="Task Details" class="w-72 bg-zinc-800 outline-none resize-none px-4 py-2"></textarea>
            <input type="submit" value="Add Task" class="px-4 py-2 bg-blue-500 w-72">
        </div>


        <div class="tasks">
            
        </div>
   </form> 
</body>
</html>