<html>
<head>
    <title>File</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a href="/" class="text-blue-500 inline-block mb-10">Go Back Home</a>
        <form action="/edit" method="post">
            <div class="form flex flex-col gap-4 mt-10">
                <input type="text" value="<%=Prevtitle%>" readonly="readonly" name="previous" placeholder="Previous Title" class="w-1/2 rounded-md text-zinc-500 bg-zinc-800 outline-none px-4 py-2">
                <input type="text" name="new" placeholder="New Title" class="w-1/2 text-slate-400 bg-zinc-800 outline-none rounded-md px-4 py-2">
                <input type="submit" value="Save Changes" class="px-4 py-2 bg-yellow-600 cursor-pointer rounded-lg w-56">
            </div>
    </div>
</body>
</html>